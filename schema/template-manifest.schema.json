{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lbliii/chirp-railway-catalog/schema/template-manifest.schema.json",
  "title": "Chirp Railway template manifest",
  "type": "object",
  "required": ["schema_version", "template", "required_categories", "checks"],
  "properties": {
    "schema_version": {"const": 1},
    "template": {
      "type": "object",
      "required": [
        "slug",
        "title",
        "repository",
        "ref",
        "python",
        "chirp_spec",
        "chirp_locked",
        "start_command",
        "health_path",
        "services",
        "variables"
      ],
      "properties": {
        "slug": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "pattern": "^https://github\\.com/"},
        "ref": {"type": "string", "minLength": 1},
        "python": {"type": "string", "minLength": 1},
        "chirp_spec": {"type": "string", "minLength": 1},
        "chirp_locked": {"type": "string", "minLength": 1},
        "start_command": {"type": "string", "minLength": 1},
        "health_path": {"type": "string", "pattern": "^/"},
        "services": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "variables": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "source", "secret"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "source": {"enum": ["railway", "template", "user"]},
              "secret": {"type": "boolean"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "required_categories": {
      "type": "array",
      "items": {
        "enum": ["asset", "form", "full-page", "health", "htmx", "oob", "readiness", "sse"]
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "path"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "category": {
            "enum": ["asset", "form", "full-page", "health", "htmx", "oob", "readiness", "sse"]
          },
          "method": {"type": "string"},
          "path": {"type": "string", "pattern": "^/"},
          "status": {"type": "integer", "minimum": 100, "maximum": 599},
          "headers": {"type": "object", "additionalProperties": {"type": "string"}},
          "request_headers": {"type": "object", "additionalProperties": {"type": "string"}},
          "body": {"type": "string"},
          "contains": {"type": "array", "items": {"type": "string"}},
          "stream": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
